---
# Managed users.
# The "ansible" user is used for automation.
# The "developer" user is used for daily development work.
users:
  - name: ansible
    state: present
    shell: /bin/bash
    groups:
      - sudo
    ssh_keys:
      - "files/ssh_keys/ansible.pub"
    sudo: true
    sudo_nopasswd: true
    password_lock: true

  - name: developer
    state: present
    shell: /bin/bash
    groups: []
    ssh_keys:
      - "files/ssh_keys/developer.pub"
    sudo: false
    sudo_nopasswd: false
    password_lock: true

# SSH access policy.
security_ssh_allow_users:
  - ansible
  - developer

# Docker access is granted only to developer users.
docker_users:
  - developer

# Developer tooling is installed only for developer users.
dev_users:
  - developer

# Git identity for developer users.
# Replace with real corporate/user values before running.
dev_git_config_enabled: true
dev_git_user_name: "Developer User"
dev_git_user_email: "developer@example.com"