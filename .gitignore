# Ansible runtime artifacts
*.retry
.ansible/
ansible.log

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Editor / OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local inventory and environment-specific variables
inventories/inventory.ini
inventories/group_vars/*.yml
inventories/host_vars/*.yml

# Keep example inventory files
!inventories/*.example
!inventories/group_vars/*.example
!inventories/host_vars/*.example
!inventories/group_vars/*.yml.example
!inventories/host_vars/*.yml.example

# SSH keys and secrets
*.pem
*.key
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# Project SSH key files
files/ssh_keys/*.pub
!files/ssh_keys/*.pub.example

# Local temporary files
tmp/
.temp/
*.tmp

# Logs
*.log